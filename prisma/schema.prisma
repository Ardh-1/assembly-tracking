// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  SUPERVISOR
  OPERATOR
}

enum UnitStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum ScanStatus {
  SUCCESS
  ERROR
  SKIPPED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  registeredUnits AssemblyUnit[]
  trackingLogs    TrackingLog[]
  sessions        Session[]
  accounts        Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model MasterProduct {
  id            String   @id @default(uuid())
  productCode   String   @unique @map("product_code")
  productName   String   @map("product_name")
  description   String?
  totalStations Int      @default(5) @map("total_stations")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  stations      Station[]
  assemblyUnits AssemblyUnit[]

  @@map("master_products")
}

model Station {
  id            String   @id @default(uuid())
  stationCode   String   @unique @map("station_code")
  stationName   String   @map("station_name")
  sequenceOrder Int      @map("sequence_order")
  productId     String?  @map("product_id")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  product       MasterProduct? @relation(fields: [productId], references: [id])
  assemblyUnits AssemblyUnit[]
  trackingLogs  TrackingLog[]

  @@map("stations")
}

model AssemblyUnit {
  id               String     @id @default(uuid())
  serialNumber     String     @unique @map("serial_number")
  productId        String     @map("product_id")
  currentStationId String?    @map("current_station_id")
  status           UnitStatus @default(PENDING)
  currentSequence  Int        @default(0) @map("current_sequence")
  registeredById   String?    @map("registered_by")
  registeredAt     DateTime   @default(now()) @map("registered_at")
  completedAt      DateTime?  @map("completed_at")

  product        MasterProduct @relation(fields: [productId], references: [id])
  currentStation Station?      @relation(fields: [currentStationId], references: [id])
  registeredBy   User?         @relation(fields: [registeredById], references: [id])
  trackingLogs   TrackingLog[]

  @@map("assembly_units")
}

model TrackingLog {
  id              String     @id @default(uuid())
  unitId          String     @map("unit_id")
  stationId       String     @map("station_id")
  operatorId      String     @map("operator_id")
  scannedAt       DateTime   @default(now()) @map("scanned_at")
  status          ScanStatus
  notes           String?
  durationSeconds Int?       @map("duration_seconds")

  unit     AssemblyUnit @relation(fields: [unitId], references: [id])
  station  Station      @relation(fields: [stationId], references: [id])
  operator User         @relation(fields: [operatorId], references: [id])

  @@map("tracking_logs")
}
